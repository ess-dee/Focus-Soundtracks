rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Rooms collection: readable by all, writable only by admins
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Config documents: readable by all, writable only by admins
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Analytics: writable by authenticated users (for incrementing), readable by admins
    match /analytics/{roomId} {
      allow read: if isAdmin();
      allow write: if request.auth != null;

      match /daily/{dateKey} {
        allow read: if isAdmin();
        allow write: if request.auth != null;
      }
    }

    // Admins collection: readable and writable only by admins
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
